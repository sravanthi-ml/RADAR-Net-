"""
Compact Transformer Encoder (CTE)
6-layer DistilBERT with spectral normalisation on all projection matrices.
Mean-pooling over token positions (+1.2% ADV-ACC over CLS-only pooling).
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from transformers import DistilBertModel
from .spectral_norm import spectral_norm_


class CompactTransformerEncoder(nn.Module):
    """
    CTE: 6-layer DistilBERT text encoder with CRL-compatible spectral norms.

    Args:
        d_model (int): Hidden dimension. Default: 768.
        dropout (float): Dropout rate. Default: 0.1.
        sigma_target (float): Spectral norm upper bound. Default: 1.0.
        pretrained_name (str): HuggingFace model identifier.
    """

    def __init__(
        self,
        d_model: int = 768,
        dropout: float = 0.1,
        sigma_target: float = 1.0,
        pretrained_name: str = "distilbert-base-uncased",
    ):
        super().__init__()
        self.d_model = d_model
        self.sigma_target = sigma_target

        # Load DistilBERT backbone
        self.encoder = DistilBertModel.from_pretrained(pretrained_name)
        self.dropout = nn.Dropout(dropout)

        # Apply spectral normalisation to all linear projections
        # Covers: W_Q, W_K, W_V, W_O per attention head + W1, W2 per FFN layer
        self._apply_spectral_norm()

    def _apply_spectral_norm(self):
        """
        Apply one-step power-iteration spectral normalisation to every
        nn.Linear weight in the transformer (satisfies CRL Lemma 1).
        σ(W_l) ≤ sigma_target enforced via hard normalisation at each forward pass.
        """
        for module in self.encoder.modules():
            if isinstance(module, nn.Linear):
                spectral_norm_(module, sigma_target=self.sigma_target)

    def forward(
        self,
        input_ids: torch.Tensor,
        attention_mask: torch.Tensor,
    ) -> torch.Tensor:
        """
        Encode token sequence to post-level representation via mean pooling.

        Args:
            input_ids: (B, T) — max T=512, [SEP]-delimited source+replies
            attention_mask: (B, T)

        Returns:
            H_text: (B, d_model=768) — mean-pooled post representation
        """
        outputs = self.encoder(
            input_ids=input_ids,
            attention_mask=attention_mask,
        )
        # outputs.last_hidden_state: (B, T, d_model)
        hidden = outputs.last_hidden_state           # (B, T, d_model)
        hidden = self.dropout(hidden)

        # Mean pooling over non-padding positions
        # More adversarially robust than CLS: perturbation of 1 token
        # shifts H_text by only 1/T of that token's displacement
        mask_expanded = attention_mask.unsqueeze(-1).float()  # (B, T, 1)
        sum_hidden = (hidden * mask_expanded).sum(dim=1)      # (B, d_model)
        count = mask_expanded.sum(dim=1).clamp(min=1e-9)      # (B, 1)
        H_text = sum_hidden / count                           # (B, d_model)

        return H_text
