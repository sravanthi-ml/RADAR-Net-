"""
Lightweight Propagation Encoder (LPE)
2-layer GCN on the social media propagation tree.
Spectrally normalised weight matrices for CRL compatibility.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch_geometric.nn import GCNConv
from torch_geometric.utils import add_self_loops, degree
from .spectral_norm import spectral_norm_


class LightweightPropagationEncoder(nn.Module):
    """
    LPE: 2-layer GCN encoding the propagation tree structure.

    Encodes: G = (V, E, A) where nodes are posts/replies.
    Output: Root node representation H_graph ∈ ℝ^d_graph.

    Constraints:
        - D_max = 5 (max propagation depth)
        - F_max = 20 (max fan-out per node)
        - Posts with < 3 replies get zero-padded virtual nodes

    Args:
        in_dim: Input node feature dimension (DistilBERT embeddings). Default: 256.
        hidden_dim: GCN layer 1 output dimension. Default: 256.
        out_dim: GCN layer 2 output dimension. Default: 128.
        sigma_target: Spectral norm target. Default: 1.0.
        dropout: Dropout rate. Default: 0.1.
    """

    def __init__(
        self,
        in_dim: int = 256,
        hidden_dim: int = 256,
        out_dim: int = 128,
        sigma_target: float = 1.0,
        dropout: float = 0.1,
    ):
        super().__init__()
        self.out_dim = out_dim
        self.sigma_target = sigma_target

        # Node feature projection: DistilBERT (768) -> d_0 (256)
        self.node_proj = nn.Linear(768, in_dim)

        # GCN layer 1: in_dim -> hidden_dim  (1-hop neighbourhood)
        # W^(1) ∈ ℝ^{256×128}
        self.conv1 = GCNConv(in_dim, hidden_dim, add_self_loops=True)

        # GCN layer 2: hidden_dim -> out_dim  (2-hop neighbourhood)
        # W^(2) ∈ ℝ^{128×128}
        self.conv2 = GCNConv(hidden_dim, out_dim, add_self_loops=True)

        self.dropout = nn.Dropout(dropout)
        self.act = nn.ReLU()

        # Apply spectral normalisation to GCN linear projections
        spectral_norm_(self.node_proj, sigma_target=sigma_target)
        spectral_norm_(self.conv1.lin, sigma_target=sigma_target)
        spectral_norm_(self.conv2.lin, sigma_target=sigma_target)

    def forward(
        self,
        node_features: torch.Tensor,
        edge_index: torch.Tensor,
        batch: torch.Tensor = None,
    ) -> torch.Tensor:
        """
        Encode propagation graph to root-node representation.

        Args:
            node_features: (N, 768) — DistilBERT embeddings per node
            edge_index: (2, E) — COO-format edge list
            batch: (N,) — node-to-graph mapping

        Returns:
            H_graph: (B, out_dim=128) — root node representation per graph
        """
        # Project node features to d_0
        x = self.node_proj(node_features)         # (N, 256)
        x = self.act(x)

        # GCN layer 1: aggregate 1-hop neighbourhood
        # H^(1) = σ(Â X_v W^(1))
        x = self.conv1(x, edge_index)             # (N, 256)
        x = self.act(x)
        x = self.dropout(x)

        # GCN layer 2: aggregate 2-hop neighbourhood
        # H^(2) = σ(Â H^(1) W^(2))
        x = self.conv2(x, edge_index)             # (N, 128)
        x = self.act(x)

        # Extract root node representation per graph
        # Root node = index 0 within each graph in the batch
        if batch is None:
            H_graph = x[0].unsqueeze(0)           # single graph
        else:
            # Root node is the first node of each graph
            _, counts = torch.unique(batch, return_counts=True)
            root_idx = torch.cumsum(
                torch.cat([torch.zeros(1, device=batch.device, dtype=torch.long),
                           counts[:-1]]), dim=0
            )
            H_graph = x[root_idx]                 # (B, out_dim)

        return H_graph

